# FurAffinity session cookies (required)
SESSION_A=
SESSION_B=

# App settings (optional, shown with defaults)
PORT=3000
METRICS_PORT=9464
CACHE_DIR=./cache
# Set to the public base URL to enable oEmbed (Discord artist attribution)
PUBLIC_URL=

# Cloudflare tunnel (required for docker-compose)
CLOUDFLARE_TUNNEL_TOKEN=

# Grafana Cloud (used by Alloy for metrics/logs shipping)
GRAFANA_METRICS_URL=
GRAFANA_METRICS_USER=
GRAFANA_LOGS_URL=
GRAFANA_LOGS_USER=
GRAFANA_API_KEY=
